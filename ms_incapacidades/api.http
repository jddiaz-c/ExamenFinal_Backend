@token = TU_TOKEN_AQUI
@base = http://localhost:8003/incapacidades

### Listar todas las incapacidades
GET {{base}}
Authorization: {{token}}

### Buscar por empleado
GET {{base}}/buscar?empleado_id=1
Authorization: {{token}}

### Buscar por rango de fechas
GET {{base}}/buscar?fecha_inicio=2026-06-01&fecha_fin=2026-06-10
Authorization: {{token}}

### Buscar por tipo
GET {{base}}/buscar?tipo=enfermedad_general
Authorization: {{token}}

### Buscar por estado
GET {{base}}/buscar?estado=registrada
Authorization: {{token}}

### Obtener una incapacidad
GET {{base}}/1
Authorization: {{token}}

### Crear incapacidad
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
    "empleado_id": 1,
    "fecha_inicio": "2026-06-01",
    "fecha_fin": "2026-06-05",
    "tipo": "enfermedad_general",
    "diagnostico_general": "Infección respiratoria",
    "entidad_medica": "Clínica Central",
    "observaciones": "Reposo médico durante cinco días"
}

### Editar incapacidad
PUT {{base}}/1
Content-Type: application/json
Authorization: {{token}}

{
    "fecha_inicio": "2026-06-02",
    "fecha_fin": "2026-06-06",
    "observaciones": "Se extendió el reposo un día más"
}

### Cambiar estado
PATCH {{base}}/1/estado
Content-Type: application/json
Authorization: {{token}}

{
    "estado": "en_revision"
}

### Finalizar incapacidad
PATCH {{base}}/1/finalizar
Authorization: {{token}}