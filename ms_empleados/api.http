@token = TU_TOKEN_AQUI
@base = http://localhost:8002/empleados

### Listar todos los empleados
GET {{base}}
Authorization: {{token}}

### Buscar por área
GET {{base}}/buscar?area=Tecnologia
Authorization: {{token}}

### Buscar por estado
GET {{base}}/buscar?estado=activo
Authorization: {{token}}

### Buscar por documento
GET {{base}}/buscar?documento=1000123456
Authorization: {{token}}

### Obtener un empleado
GET {{base}}/1
Authorization: {{token}}

### Crear empleado
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
    "nombres": "Juan David",
    "apellidos": "García López",
    "documento": "1234567890",
    "correo": "juandavid@empresa.com",
    "telefono": "3001234567",
    "cargo": "Desarrollador",
    "area": "Tecnologia",
    "fecha_ingreso": "2026-01-15"
}

### Editar empleado
PUT {{base}}/1
Content-Type: application/json
Authorization: {{token}}

{
    "cargo": "Desarrollador Senior",
    "area": "Tecnologia"
}

### Cambiar estado
PATCH {{base}}/1/estado
Content-Type: application/json
Authorization: {{token}}

{
    "estado": "inactivo"
}